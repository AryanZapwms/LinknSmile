# ============================================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it is already in .gitignore.
# ============================================================

# --- Database ---
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority"

# --- Authentication & Sessions ---
# Your deployed URL (no trailing slash). Use http://localhost:3004 for local dev.
NEXTAUTH_URL="https://linkn-smile.vercel.app"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-string"

# --- Email (Gmail SMTP) ---
# Use a Gmail account with 2FA enabled and an App Password (not your real password).
# Create one at: https://myaccount.google.com/apppasswords
GMAIL_EMAIL="your-app-email@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"
# Optional — defaults to GMAIL_EMAIL if not set
EMAIL_FROM="Instapeels <your-app-email@gmail.com>"

# --- Razorpay ---
# Test keys start with rzp_test_, live keys start with rzp_live_
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="your-razorpay-secret"
# This one is exposed to the browser — must be the Key ID only, never the secret
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"

# --- Analytics & Tracking (optional but configured in layout.tsx) ---
FACEBOOK_PIXEL_ID="your-pixel-id"
GOOGLE_TAG_MANAGER_ID="GTM-XXXXXXX"
GOOGLE_ADS_ID="AW-XXXXXXXXX"

# --- Cloudinary (for image uploads) ---
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
